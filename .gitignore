# ============================================================
# CodeMentor — .gitignore
# ============================================================

# ── Node.js ──────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
package-lock.json
yarn.lock

# ── Environment Variables ────────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
*.env

# ── Build Outputs ────────────────────────────────────────────
dist/
build/
out/
.next/
.nuxt/
.cache/
.parcel-cache/

# ── React / Vite ─────────────────────────────────────────────
frontend/dist/
frontend/.vite/

# ── Backend ──────────────────────────────────────────────────
backend/dist/
backend/logs/
backend/*.log

# ── Judge0 / Docker ──────────────────────────────────────────
judge0/data/
judge0/postgres-data/
judge0/redis-data/

# ── Editors / IDEs ───────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ── Testing ──────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── Temporary Files ──────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak

# ── Secrets / Certificates ───────────────────────────────────
*.pem
*.key
*.crt
*.p12

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
