# ── CodeSphere backend environment (copy to .env and fill in) ──────────────────
NODE_ENV=production
PORT=3001

# Comma-separated allowed origins (your Vercel domain + localhost for dev).
# Example: https://codementor.vercel.app,http://localhost:5173
CORS_ORIGIN=https://YOUR-FRONTEND.vercel.app,http://localhost:5173

# Postgres (Supabase connection string). Use the pooled URL for serverless,
# or the direct URL for a long-running server/worker.
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Redis (BullMQ queue). On a Droplet with docker-compose this is the redis service.
REDIS_URL=redis://localhost:6379

# Auth secrets — generate long random strings (e.g. `openssl rand -hex 32`)
JWT_SECRET=change_me_long_random
JWT_REFRESH_SECRET=change_me_another_long_random

# Self-hosted Judge0 base URL (internal Docker DNS in compose, or its private IP/host)
JUDGE0_URL=http://judge0_server:2358
# Optional: if Judge0 has AUTHN_TOKEN set in judge0.conf, mirror it here
# JUDGE0_AUTH_TOKEN=

# AI tutor — Google AI Studio key (starts with AIza... or AQ...)
GEMINI_API_KEY=

# Google OAuth — same client id as the frontend's VITE_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_ID=

# JPlag (plagiarism) — set if the JAR isn't at the default backend/jplag/jplag.jar
# JPLAG_JAR_PATH=/app/jplag/jplag.jar
